PORT=3000
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
API_KEY=your-secret-api-key
NODE_ENV=development
LOG_LEVEL=info

# Kommo ChatAPI (Phase A) — optional, Phase B works without these
KOMMO_CHANNEL_ID=
KOMMO_CHANNEL_SECRET=
KOMMO_SCOPE_ID=
KOMMO_AMOJO_ID=

# Kommo Private Integration (REST API v4)
KOMMO_SUBDOMAIN=your-subdomain
KOMMO_PRIVATE_TOKEN=your-long-lived-token

# WhatsApp Cloud API (Coexistence mode)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=your-app-secret  # REQUIRED — webhook signature verification
